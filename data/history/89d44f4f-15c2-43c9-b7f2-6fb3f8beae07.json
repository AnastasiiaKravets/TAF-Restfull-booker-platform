se_products = CartResponse(id=209, products=[CartProduct(id=40, title='Strawberry', price=3.99, quantity=23, total=91.77000000000001...humbnail.webp'))], total=3855.7200000000003, discounted_total=3138.0, user_id=59, total_products=3, total_quantity=128)\nexact_match = True\n\n    def assert_products_in_cart(payload_products: BaseModel, response_products: BaseModel, exact_match=False):\n        expected = {(product.id, product.quantity) for product in payload_products.products}\n        actual = {(product.id, product.quantity) for product in response_products.products}\n    \n        if exact_match:\n>           assert expected == actual, (f'Different products id or quantity. \\n'\n                   ^^^^^^^^^^^^^^^^^^\n                                        f'Expected (id, quantity):{expected}, \\n'\n                                        f'Actual (id, quantity):  {actual}')\nE           AssertionError: Different products id or quantity. \nE           Expected (id, quantity):{(56, 99), (85, 6), (40, 23)}, \nE           Actual (id, quantity):  {(85, 99), (56, 6), (40, 23)}\n\nsrc/API/dummy_json_service/helpers/API_assertions.py:42: AssertionError","start":1784585001836,"stop":1784585001968,"duration":132,"labels":[{"name":"tag","value":"api"},{"name":"parentSuite","value":"test.API.dummy_json_service"},{"name":"suite","value":"test_carts"},{"name":"host","value":"runnervm3jd5f"},{"name":"thread","value":"3184-MainThread"},{"name":"framework","value":"pytest"},{"name":"language","value":"cpython3"},{"name":"package","value":"test.API.dummy_json_service.test_carts"}],"url":"","historyId":"5188b751c1bf2db8a98866450746aa90.d41d8cd98f00b204e9800998ecf8427e","reportLinks":[]},"0f413da433e01964226efacd204a7649.8faf58a537531c43cac328708c3e67fd":{"id":"3d78b8f52b8ce4234fe090199954eb11","name":"test_authorize_user_with_invalid_credentials[credentials_override2-Invalid credentials]","fullName":"test.API.dummy_json_service.test_auth#test_authorize_user_with_invalid_credential